{
  "name": "eloquent-orm-js-advanced-integration",
  "version": "1.0.0",
  "description": "Advanced consumer-project validation harness for @alpha.consultings/eloquent-orm.js with Express, JWT auth, refresh tokens, PostgreSQL, Memcached, and Docker-backed integration tests.",
  "license": "Apache-2.0",
  "author": "mekherbeche fares",
  "private": true,
  "type": "commonjs",
  "main": "index.js",
  "homepage": "https://github.com/MetalDz/eloquent-orm-js-advanced-integration",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MetalDz/eloquent-orm-js-advanced-integration.git"
  },
  "bugs": {
    "url": "https://github.com/MetalDz/eloquent-orm-js-advanced-integration/issues"
  },
  "keywords": [
    "eloquent-orm",
    "nodejs",
    "typescript",
    "express",
    "postgresql",
    "memcached",
    "jwt",
    "docker",
    "rest-api",
    "integration-testing"
  ],
  "scripts": {
    "dev": "ts-node src/server.ts",
    "app:start": "node scripts/app-start.cjs",
    "app:stop": "node scripts/app-stop.cjs",
    "build": "tsc -p tsconfig.json",
    "migrate:pg": "npx eloquent migrate:fresh --pg --force",
    "seed:pg": "npx eloquent db:seed --pg --class BlogScenarioSeeder",
    "test": "node scripts/run-node-tests.cjs",
    "test:integration": "node scripts/run-node-tests.cjs --integration",
    "test:coverage": "node scripts/run-node-tests.cjs --coverage",
    "test:docker": "node scripts/run-docker-integration.cjs"
  },
  "dependencies": {
    "@alpha.consultings/eloquent-orm.js": "^1.0.4",
    "@faker-js/faker": "^10.4.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/memcached": "^2.2.10",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
